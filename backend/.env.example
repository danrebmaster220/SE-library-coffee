# ===========================================
# Library Coffee + Study Backend Configuration
# ===========================================
# Copy this file to .env and update the values
# NEVER commit your actual .env file to git!

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
NODE_ENV=development
# Options: development | production

# ===========================================
# Database Configuration
# ===========================================
# For local MariaDB/MySQL:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=coffee_db

# For cloud databases (Railway, PlanetScale, etc.):
# DB_HOST=your-database-host.railway.app
# DB_PORT=xxxxx  # Railway uses random ports, NOT 3306!
# DB_USER=your_username
# DB_PASS=your_password
# DB_NAME=railway
# DB_SSL=true  # Enable SSL for cloud database connections

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Generate a strong random string for production!
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=library-coffee-secret-key-2024-change-in-production

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins (no spaces after commas)
# Development example:
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081

# Production example:
# CORS_ORIGINS=https://pos.yourdomain.com,https://kiosk.yourdomain.com

# ===========================================
# Optional: Printer Configuration
# ===========================================
# Only needed if using local thermal printing
PRINTER_NAME=POS-58

